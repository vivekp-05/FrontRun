{
  "name": "frontrun_enrich_verify_draft",
  "description": "Frontrun Track B RocketRide pipeline: detect a fresh SEC Form D company, research it with You.com, scrape/enrich contact data, verify confidence, and draft first-touch outreach.",
  "version": "0.1.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "domain": {
        "type": "string",
        "description": "Optional company domain for Firecrawl/Hunter enrichment."
      },
      "persist": {
        "type": "boolean",
        "description": "Persist through InsForge StoreProvider when A's route is available."
      },
      "includeFunds": {
        "type": "boolean",
        "description": "Allow fund/LP Form D filings instead of preferring operating companies."
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "steps": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "lead": {
        "type": "object"
      }
    },
    "required": [
      "steps",
      "lead"
    ]
  },
  "patch_sequence": [
    "POST lead (DETECTED)",
    "upsert researchSummary/brief (status untouched)",
    "upsert contact + transition ENRICHED",
    "upsert leadScore",
    "upsert draft + transition DRAFTED"
  ],
  "entrypoint": {
    "type": "command",
    "command": "npm",
    "args": [
      "run",
      "track-b:run",
      "--",
      "--json-stdin"
    ],
    "env_file": ".env.local",
    "cwd": "."
  },
  "stages": [
    "detect_form_d",
    "confirm_and_research",
    "scrape_company",
    "resolve_and_verify_email",
    "draft_outreach",
    "optional_persist"
  ],
  "tags": [
    "track-b",
    "you.com",
    "nimble",
    "rocketride",
    "form-d"
  ]
}
